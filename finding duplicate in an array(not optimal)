arr = input("Enter the elements of the array: ").split()

is_duplicate = False

for i in range(len(arr)):
    for j in range(i + 1, len(arr)):
        if arr[i] == arr[j]:
            is_duplicate = True
            print("Duplicate element:", arr[i])
            break

if is_duplicate:
    print("The array contains duplicates.")
else:
    print("The array does not contain duplicates.")
